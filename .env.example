# Server
NODE_ENV=development
PORT=5001
API_PREFIX=/api/v1

# Database
MONGODB_URI=mongodb://localhost:27017/smart-society

# JWT (use strong secrets in production)
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REMEMBER_ME_EXPIRES_IN=30d
PASSWORD_RESET_EXPIRES_IN=1h

# Super Admin seed
SUPER_ADMIN_EMAIL=admin@smartsociety.com
SUPER_ADMIN_PASSWORD=Admin@123456

# CORS & Cookies
CORS_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=localhost

# Client URL (for redirects, emails, etc.)
CLIENT_URL=http://localhost:5173

# Email (optional — logs to console when empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@smartsociety.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
API_RATE_LIMIT_MAX_REQUESTS=60
